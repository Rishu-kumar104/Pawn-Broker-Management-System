# Copy this file to .env and replace with your REAL Postgres connection string.
# Do NOT use HOST, USER, PASSWORD, or DATABASE as literal values.

# Neon example:
# DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# Supabase example:
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require"

DATABASE_URL="postgresql://YOUR_USER:YOUR_PASSWORD@YOUR_REAL_HOST:5432/YOUR_DB_NAME?sslmode=require"
